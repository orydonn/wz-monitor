TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
POLL_INTERVAL_MS=10000
STORAGE_STATE_PATH=./storageState.json
SEEN_STORE_PATH=./seen.json
WZ_FREELANCER_URL=https://client.work-zilla.com/freelancer
LOG_LEVEL=info

# Auto-draft pipeline (claude -p via Claude.ai subscription)
DRAFT_ENABLED=true
CLAUDE_BIN=claude
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_EFFORT=high
CLAUDE_TIMEOUT_MS=90000
TMP_DIR=./tmp/wz
MAX_FILE_BYTES=5242880
MAX_TOTAL_BYTES=20971520
MAX_FILES_PER_TASK=10
AUTO_POST=false
MAX_POSTS_PER_HOUR=12

# Inbox alerts — second TG bot for customer-reply notifications
TELEGRAM_INBOX_BOT_TOKEN=
INBOX_POLL_INTERVAL_MS=30000
INBOX_STORE_PATH=./inbox-seen.json
CURRENT_ORDERS_URL=https://client.work-zilla.com/freelancer/current-orders

# Followup engine — auto-continue the chat after the first offer
FOLLOWUP_ENABLED=true
FOLLOWUP_DELAY_MS=240000
FOLLOWUP_JITTER_MS=180000
FOLLOWUP_MAX_PER_TASK=3
FOLLOWUP_STORE_PATH=./followup-state.json
FOLLOWUP_AUTO_DECLINE=true

# Task dump — auto-create wzd-style folders when a task is accepted (enters В работе)
# Set WZ_TASKS_DIR to enable. On WSL+Windows: /mnt/e/wz-tasks
WZ_TASKS_DIR=
WZ_TASKS_DUMP_PATH=./tasks-dumped.json
